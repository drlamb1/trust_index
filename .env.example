# =============================================================================
# EdgeFinder — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL (serverless)
# Get from: https://console.neon.tech → Connection Details → Connection string
# Format: postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/edgefinder?sslmode=require

# -----------------------------------------------------------------------------
# Redis — Upstash (serverless, SSL required)
# Get from: https://console.upstash.com → Redis → Connect → .env
# Format: rediss://default:PASSWORD@HOST.upstash.io:6379
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# -----------------------------------------------------------------------------
# Anthropic — Claude API
# Get from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# -----------------------------------------------------------------------------
# Market Data APIs
# -----------------------------------------------------------------------------

# Alpha Vantage — price data fallback (free: 25 req/day)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Polygon.io — better price data, options (free tier: 5 req/min, EOD only)
# Get from: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=

# Finnhub — news, earnings calendar (free: 60 req/min)
# Get from: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Financial Modeling Prep — earnings transcripts, financial data (free: 250 req/day)
# Get from: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# NewsAPI — news aggregation (free: 100 req/day)
# Get from: https://newsapi.org/account
NEWS_API_KEY=

# FRED — economic data (rates, GDP, etc.) — free
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -----------------------------------------------------------------------------
# SEC EDGAR — Required by SEC policy (must include real email)
# Format: "AppName/Version contact@yourdomain.com"
# -----------------------------------------------------------------------------
EDGAR_USER_AGENT=EdgeFinder/1.0 your@email.com

# -----------------------------------------------------------------------------
# Alert Delivery
# -----------------------------------------------------------------------------

# Email via SendGrid (or any SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxx
SMTP_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=you@email.com

# Slack — create an Incoming Webhook app
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Discord — right-click channel → Edit Channel → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# ntfy.sh — no account needed, pick a unique topic name
NTFY_TOPIC=edgefinder-alerts-unique-topic-name
NTFY_SERVER=https://ntfy.sh

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=generate-with-python-secrets-token-hex-32
ENVIRONMENT=development
LOG_LEVEL=INFO
DASHBOARD_PORT=8050
DASHBOARD_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Allow public user registration (default: false — use CLI to create users)
REGISTRATION_ENABLED=false

# -----------------------------------------------------------------------------
# Production Hardening
# -----------------------------------------------------------------------------

# CORS allowed origins (comma-separated). Use * for dev, restrict in production.
# Example: https://edgefinder-production.up.railway.app,https://example.com
CORS_ORIGINS=*

# Chat endpoint rate limit (slowapi format)
CHAT_RATE_LIMIT=10/minute
